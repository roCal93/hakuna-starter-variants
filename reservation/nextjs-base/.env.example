# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_NAME=Nom du restaurant

# Schema.org (Restaurant)
# NEXT_PUBLIC_SCHEMA_DESCRIPTION=Restaurant experience with seasonal cuisine and warm service
# NEXT_PUBLIC_SCHEMA_LOGO=https://ton-site.com/images/logo.png
# NEXT_PUBLIC_SCHEMA_TELEPHONE=+33123456789
# NEXT_PUBLIC_SCHEMA_EMAIL=contact@ton-site.com
# NEXT_PUBLIC_SCHEMA_STREET_ADDRESS=123 Rue Exemple
# NEXT_PUBLIC_SCHEMA_CITY=Paris
# NEXT_PUBLIC_SCHEMA_POSTAL_CODE=75001
# NEXT_PUBLIC_SCHEMA_COUNTRY=FR
# NEXT_PUBLIC_SCHEMA_AREA_SERVED=Paris
# NEXT_PUBLIC_SCHEMA_PRICE_RANGE=EUR 20-60
# NEXT_PUBLIC_SCHEMA_CUISINE=French,Mediterranean
# NEXT_PUBLIC_SCHEMA_MENU=https://ton-site.com/menu
# NEXT_PUBLIC_SCHEMA_ACCEPTS_RESERVATIONS=true
# NEXT_PUBLIC_SCHEMA_LATITUDE=48.8566
# NEXT_PUBLIC_SCHEMA_LONGITUDE=2.3522
# NEXT_PUBLIC_SCHEMA_SAME_AS=https://instagram.com/toncompte,https://facebook.com/toncompte
# NEXT_PUBLIC_SCHEMA_OPENING_HOURS=[{"dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday"],"opens":"12:00","closes":"14:30"},{"dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],"opens":"19:00","closes":"22:30"}]

# Strapi
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
# STRAPI_API_TOKEN= # Token API (read-only) - optional for public builds
# STRAPI_WRITE_API_TOKEN= # Token API with write permissions for reservations/admin actions
# STRAPI_PREVIEW_TOKEN= # Token de preview (used for draft preview)
STRAPI_API_TOKEN=votre-token-de-dev
STRAPI_WRITE_API_TOKEN=votre-token-write-de-dev
STRAPI_PREVIEW_TOKEN=votre-preview-token

# Preview / Drafts
PREVIEW_SECRET=changeme
USE_DRAFT_MODE=false

# ISR Revalidation (optionnel - pour revalidation instantanée)
REVALIDATE_SECRET=changeme

# Contact Form (optionnel - pour formulaire de contact)
# COMPANY_NAME="Votre Entreprise"
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM_EMAIL=contact@mail.votre-domaine.com
# CONTACT_EMAIL=destinataire@email.com

# API Security / Rate limiting (optionnel mais recommande en production)
# UPSTASH_REDIS_REST_URL=https://<your-db-endpoint>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<your-upstash-rest-token>
# PUBLIC_API_ALLOWED_ORIGINS=https://votre-domaine.com,https://www.votre-domaine.com

# Admin Dashboard (espace restaurateur)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_SECRET=une-cle-secrete-aleatoire-32-chars

# Pour production, décommente et adapte :
# NEXT_PUBLIC_SITE_URL=https://ton-site.com
# NEXT_PUBLIC_STRAPI_URL=https://strapi-deploy.up.railway.app

# Note: after switching Strapi uploads to Cloudinary, ensure NEXT_PUBLIC_STRAPI_URL is set in Vercel and redeploy Next to fetch updated image URLs
